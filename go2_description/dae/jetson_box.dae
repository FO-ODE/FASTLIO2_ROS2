<?xml version="1.0" encoding="utf-8"?>
<COLLADA xmlns="http://www.collada.org/2005/11/COLLADASchema" version="1.4.1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <asset>
    <created>2026-06-03T00:00:00</created>
    <modified>2026-06-03T00:00:00</modified>
    <unit name="meter" meter="1"/>
    <up_axis>Z_UP</up_axis>
  </asset>
  <library_effects>
    <effect id="base_color-effect">
      <profile_COMMON>
        <technique sid="common">
          <lambert>
            <emission>
              <color sid="emission">0 0 0 1</color>
            </emission>
            <diffuse>
              <color sid="diffuse">0.18 0.18 0.18 1</color>
            </diffuse>
          </lambert>
        </technique>
      </profile_COMMON>
    </effect>
  </library_effects>
  <library_materials>
    <material id="base_color-material" name="base_color">
      <instance_effect url="#base_color-effect"/>
    </material>
  </library_materials>
  <library_geometries>
    <geometry id="jetson_box-mesh" name="jetson_box">
      <mesh>
        <source id="jetson_box-positions">
          <float_array id="jetson_box-positions-array" count="24">-0.0925 -0.0525 -0.015 0.0925 -0.0525 -0.015 0.0925 0.0525 -0.015 -0.0925 0.0525 -0.015 -0.0925 -0.0525 0.015 0.0925 -0.0525 0.015 0.0925 0.0525 0.015 -0.0925 0.0525 0.015</float_array>
          <technique_common>
            <accessor source="#jetson_box-positions-array" count="8" stride="3">
              <param name="X" type="float"/>
              <param name="Y" type="float"/>
              <param name="Z" type="float"/>
            </accessor>
          </technique_common>
        </source>
        <vertices id="jetson_box-vertices">
          <input semantic="POSITION" source="#jetson_box-positions"/>
        </vertices>
        <triangles material="base_color-material" count="12">
          <input semantic="VERTEX" source="#jetson_box-vertices" offset="0"/>
          <p>0 2 1 0 3 2 4 5 6 4 6 7 1 2 6 1 6 5 0 4 7 0 7 3 3 7 6 3 6 2 0 1 5 0 5 4</p>
        </triangles>
      </mesh>
    </geometry>
  </library_geometries>
  <library_visual_scenes>
    <visual_scene id="Scene" name="Scene">
      <node id="jetson_box" name="jetson_box" type="NODE">
        <instance_geometry url="#jetson_box-mesh" name="jetson_box">
          <bind_material>
            <technique_common>
              <instance_material symbol="base_color-material" target="#base_color-material"/>
            </technique_common>
          </bind_material>
        </instance_geometry>
      </node>
    </visual_scene>
  </library_visual_scenes>
  <scene>
    <instance_visual_scene url="#Scene"/>
  </scene>
</COLLADA>
